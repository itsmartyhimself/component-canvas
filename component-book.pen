              },
              "cornerRadius": 40,
              "stroke": {
                "align": "inside",
                "thickness": 1
              },
              "gap": 8,
              "padding": [
                16,
                12
              ],
              "justifyContent": "center",
              "alignItems": "center"
            },
            {
              "type": "frame",
              "id": "rXbsX",
              "name": "Nav-ThemeToggle",
              "context": "<!-- ## Nav-ThemeToggle\n**Type:** theme toggle trigger\n**Component:** DashboardNav-ThemeToggle\n### Design notes\n- 36×36 circle (radius 40), same dark→cool-blue→cream gradient as Nav-Avatar (placeholder fill until the real toggle icon ships).\n### For AI agents\n- Bind to the existing lightmode/darkmode toggle so the dashboard shell respects the same theme as the runtime app (already hooked up there).\n- Replace the gradient placeholder fill with the actual sun/moon glyph once that asset exists.\n-->",
              "width": 36,
              "height": 36,
              "fill": {
                "type": "gradient",
                "gradientType": "linear",
                "enabled": true,
                "rotation": -180,
                "size": {
