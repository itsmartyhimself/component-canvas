    {
      "type": "frame",
      "id": "AOMDJ",
      "x": 8828,
      "y": 3771,
      "name": "Tag System & Gradients — Docs",
      "width": 560,
      "fill": "$color-bg-primary",
      "cornerRadius": "$radius-3",
      "stroke": {
        "align": "inside",
        "thickness": 1,
        "fill": "$color-border-primary"
      },
      "layout": "vertical",
      "gap": 20,
      "padding": 24,
      "children": [
        {
          "type": "text",
          "id": "LSSDC",
          "name": "title",
          "fill": "$color-text-primary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "Tag color system",
          "fontFamily": "$font-sans",
          "fontSize": "$type-7-size",
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "i4gAQ",
          "name": "intro",
          "fill": "$color-text-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "Six (wash, ink) pairs for status and category labels — chips, pills, badges, banners, dots. They are NOT brand or marketing colors. Each pair: wash = soft fill, ink = strong accent for icon, dot, border, or solid background.",
          "lineHeight": 1.5,
          "fontFamily": "$font-sans",
          "fontSize": "$type-4-size",
          "fontWeight": "normal"
        },
        {
          "type": "frame",
          "id": "d2xYdU",
          "name": "Roles",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 8,
          "children": [
            {
              "type": "text",
              "id": "vztp5",
              "name": "rowSuccess",
              "fill": "$color-text-primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "tag-success — positive/healthy: synced, completed, live, active, online, stable.",
              "fontFamily": "$font-sans",
              "fontSize": "$type-3-size",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "JnaRp",
              "name": "rowWarning",
              "fill": "$color-text-primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "tag-warning — needs attention but not broken: pending, expiring, throttled, beta, in-progress.",
              "fontFamily": "$font-sans",
              "fontSize": "$type-3-size",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "fyJ8L",
              "name": "rowInfo",
              "fill": "$color-text-primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "tag-info — neutral information: draft, scheduled, in review, syncing, note. Use for things that aren't a state — just a label.",
              "fontFamily": "$font-sans",
              "fontSize": "$type-3-size",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "y0bCo",
              "name": "rowDanger",
              "fill": "$color-text-primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "tag-danger — errors and destructive: failed, blocked, removed, critical, deprecated. Doubles as the failure/destructive color.",
              "fontFamily": "$font-sans",
              "fontSize": "$type-3-size",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "PfD5C",
              "name": "rowLime",
              "fill": "$color-text-primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "tag-highlight — high-energy spotlight, no severity: NEW, FEATURED, TRENDING, recently-added markers. The bright lime wash is meant to grab the eye on cards/list rows. Don't use as a status.",
              "fontFamily": "$font-sans",
              "fontSize": "$type-3-size",
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "VUtMA",
              "name": "rowEarth",
              "fill": "$color-text-primary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "tag-archive — historic/low-priority: archived, paused, sandbox, draft envs, legacy. The warm faded combo signals 'still here, but not active'.",
              "fontFamily": "$font-sans",
              "fontSize": "$type-3-size",
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "text",
          "id": "BlYzI",
          "name": "usage",
          "fill": "$color-text-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "Usage rules:\n1) These are for status/category coding only. A neutral chip with no semantic should use --color-bg-tertiary + --color-text-primary.\n2) Solid variant: ink as fill + white text.\n3) Subtle variant: wash as fill + ink as icon/dot/border + --color-text-primary for the label text. (warning and info inks are too light for label text on white — never use them as text color, only as accent.)\n4) Don't mix tag families inside one component or one row of chips. Pick the family per cell, not per token.",
          "lineHeight": 1.5,
          "fontFamily": "$font-sans",
          "fontSize": "$type-3-size",
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "cMzlE",
          "name": "gradTitle",
          "fill": "$color-text-primary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "Gradients",
          "fontFamily": "$font-sans",
          "fontSize": "$type-7-size",
          "fontWeight": "600"
        },
        {
          "type": "text",
          "id": "xqzjZ",
          "name": "gradIntro",
          "fill": "$color-text-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "Stored as string variables (gradient-dawn, gradient-dusk, gradient-daylight) because pen color tokens can't hold gradient stops. Use as decorative surfaces only — hero backgrounds, splash, time-of-day moments. Recreate as a gradient fill matching the CSS in the variable.",
          "lineHeight": 1.5,
          "fontFamily": "$font-sans",
          "fontSize": "$type-3-size",
          "fontWeight": "normal"
        }
      ]
    },
