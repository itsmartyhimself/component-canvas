                                  "fill": "#6d6467",
                                  "content": "Continue with GitHub",
                                  "lineHeight": 1,
                                  "fontFamily": "Geist",
                                  "fontSize": 14,
                                  "fontWeight": "500"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "Nqeid",
                              "name": "AuthButton-github-default-final",
