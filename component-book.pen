                              "width": 16,
                              "height": 16,
                              "iconFontName": "layers",
                              "iconFontFamily": "lucide",
                              "fill": "#ffffff"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "pGEQf",
                          "name": "loginWord",
                          "fill": "#121111",
                          "content": "Component Canvas",
                          "lineHeight": 1.1,
                          "fontFamily": "Geist",
                          "fontSize": 14,
                          "fontWeight": "500"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "hN1zn",
                      "name": "Header",
                      "context": "title + subtitle pair, centered. same typographic stack pattern as the hero on the connect flow (ConnectRepo-Header) — just without the gradient background. likely one shared HeroText component once it appears in a third place.",
                      "width": 462,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1
                      },
                      "layout": "vertical",
                      "gap": 8,
                      "padding": [
                        0,
