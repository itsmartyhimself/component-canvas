{
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "rootDir": "src",
    "outDir": "lib",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["es2022"],
    "target": "es2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": true,
    "sourceMap": true
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
