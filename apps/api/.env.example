# apps/api environment. Copy to apps/api/.env.local (gitignored) and fill in.
# Real values are NEVER committed. On Railway these are set as service variables.

# --- Server ---
# Injected by Railway. Locally defaults to 4000 when unset.
PORT=

# --- Supabase (server-side, privileged) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- GitHub App (usemount.dev) ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# PEM private key, base64-encoded to a single line. Decoded at runtime.
GITHUB_APP_PRIVATE_KEY_BASE64=
