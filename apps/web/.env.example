# apps/web environment. Copy to apps/web/.env.local (gitignored) and fill in.
# NEXT_PUBLIC_* values are exposed to the browser by design. Real values are
# NEVER committed. On Railway these are set as service variables.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only (route handlers / RSC). NOT NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# --- API ---
# usemount.dev Hono API base URL. Local default http://localhost:4000.
NEXT_PUBLIC_API_URL=
